@rendermode InteractiveServer
@inherits LayoutComponentBase

<div class="min-h-screen flex bg-slate-950 text-white">

    <aside class="w-64 shrink-0 border-r border-white/5 flex flex-col px-4 py-6">
        <div class="flex items-center gap-2 px-2 mb-8">
            <svg class="w-7 h-7 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <span class="text-lg font-bold tracking-tight">PicoNet</span>
        </div>

        <NavMenu />
    </aside>

    <main class="flex-1 overflow-y-auto">
        @Body
    </main>

</div>

<div id="blazor-error-ui" class="fixed bottom-4 right-4 z-50 hidden" data-nosnippet>
    <div class="bg-red-600 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4">
        <span>An unhandled error has occurred.</span>
        <a href="." class="underline font-medium">Reload</a>
    </div>
</div>