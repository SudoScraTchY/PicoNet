@rendermode InteractiveServer
@using PicoNet.UI.Components.Shared
@inherits LayoutComponentBase
<div class="min-h-screen bg-background text-foreground">
    @* Ambient background *@
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
        <div class="
            absolute
            left-[-10rem]
            top-[-10rem]
            h-[30rem]
            w-[30rem]
            rounded-full
            bg-primary-500/10
            blur-3xl">
        </div>
        <div class="
            absolute
            bottom-[-14rem]
            right-[-12rem]
            h-[34rem]
            w-[34rem]
            rounded-full
            bg-accent-500/10
            blur-3xl">
        </div>
    </div>
    <div class="relative flex min-h-screen">
        @* Sidebar *@
        <aside class="
            fixed
            inset-y-0
            left-0
            w-72
            border-r
            border-border
            bg-surface-0/80
            backdrop-blur-xl">
            <div class="flex h-full flex-col">
                <div class="
                    flex-1
                    overflow-y-auto
                    px-4
                    py-5">
                    <NavMenu />
                </div>
            </div>
        </aside>
        @* Main *@
        <div class="ml-72 flex-1">
            <header class="
                sticky
                top-0
                z-30
                border-b
                border-border
                bg-background/70
                backdrop-blur-xl">
                <div class="
                    flex
                    items-center
                    justify-between
                    px-7
                    py-2">
                    <div>
                        <h1 class="
                            text-lg
                            font-bold">
                            Dashboard
                        </h1>
                        <p class="
                            text-sm
                            text-muted">
                            Manage links and analytics
                        </p>
                    </div>
                    <div class="space-x-3 gap-x-3 flex flex-row-reverse flex-auto    ">
                        <div class="
                            rounded-2xl
                            border
                            border-[var(--color-border)]
                            bg-[var(--color-surface-50)]
                            p-3">
                            <ThemeToggle />
                        </div>
                        <div class="
                                rounded-2xl
                                border
                                border-[var(--color-border)]
                                bg-[var(--color-surface-50)]
                                p-3">
                            <PaletteSwitcher />
                        </div>
                    </div>
                </div>
            </header>
            <main class="
                px-1
                py-1">
                @Body
            </main>
        </div>
    </div>
</div>
<div
    id="blazor-error-ui"
    class="
        fixed
        bottom-6
        right-6
        hidden"
    data-nosnippet>
    <div class="
        rounded-3xl
        border
        border-error/20
        bg-surface-0
        px-5
        py-4
        shadow-xl">
        <div class="
            font-semibold
            text-error">
            Something went wrong
        </div>
        <a
            href="."
            class="
                mt-3
                inline-flex
                rounded-xl
                bg-primary-500
                px-4
                py-2
                text-white">
            Reload
        </a>
    </div>
</div>