@inherits LayoutComponentBase
@using PicoNet.UI.Components.Shared
@implements IDisposable

<div class="min-h-screen flex flex-col bg-[var(--color-bg-primary)] text-[var(--color-text-primary)]">
    <!-- Error UI -->
    <div id="blazor-error-ui" class="fixed bottom-4 right-4 z-50 hidden" data-nosnippet>
        <div class="bg-red-600 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4">
            <span>An unhandled error has occurred.</span>
            <a href="." class="underline font-medium hover:no-underline">Reload</a>
            <button class="ml-2 text-xl leading-none opacity-70 hover:opacity-100" onclick="document.getElementById('blazor-error-ui').classList.add('hidden')">×</button>
        </div>
    </div>
    <!-- Global controls (top right) -->
    <div class="fixed top-4 right-4 z-50 flex items-center gap-3">
        <ThemeSelector />
        <DarkModeToggle />
    </div>

    <main class="flex-1">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized() { }
    public void Dispose() { }
}