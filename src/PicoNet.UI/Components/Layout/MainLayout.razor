@using PicoNet.UI.Components.Shared
@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="min-h-screen flex flex-col bg-background text-foreground transition-colors duration-500">
    <!-- Blazor Error UI -->
    <div id="blazor-error-ui" class="fixed bottom-4 right-4 z-50 hidden" data-nosnippet>
        <div class="bg-error text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4">
            <span>An unhandled error has occurred.</span>
            <a href="." class="underline font-medium hover:no-underline">Reload</a>
            <button class="ml-2 text-xl leading-none opacity-70 hover:opacity-100" onclick="document.getElementById('blazor-error-ui').classList.add('hidden')">×</button>
        </div>
    </div>

    <!-- Header -->
    <header class="sticky top-0 z-40 w-full border-b border-border glass transition-colors duration-500">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            <a href="/" class="flex items-center gap-3 group">
                <div class="relative size-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center shadow-lg shadow-primary-500/25 group-hover:shadow-primary-500/40 transition-shadow duration-300">
                    <svg class="size-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-lg font-bold tracking-tight leading-none">NimMas</span>
                    <span class="text-[10px] text-muted font-medium tracking-widest uppercase">نیم مسیر</span>
                </div>
            </a>

            <div class="flex items-center gap-3">
                <PaletteSwitcher />
                <div class="h-6 w-px bg-border"></div>
                <ThemeToggle />
            </div>
        </div>
    </header>

    <main class="flex-1 relative">
        @Body
    </main>

    <footer class="border-t border-border bg-surface-50/50 backdrop-blur-sm">
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-muted">NimMas.ir — کوتاه‌کننده لینک هوشمند</p>
            <div class="flex items-center gap-6">
                <a href="/" class="text-sm text-muted hover:text-foreground transition-colors">Home</a>
                <a href="/" class="text-sm text-muted hover:text-foreground transition-colors">API</a>
                <a href="/" class="text-sm text-muted hover:text-foreground transition-colors">GitHub</a>
            </div>
        </div>
    </footer>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initTheme");
        }
    }
}