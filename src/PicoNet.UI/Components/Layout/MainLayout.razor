@inherits LayoutComponentBase

<div class="min-h-screen bg-app text-app transition-colors duration-500">
    <div id="blazor-error-ui" class="fixed bottom-4 right-4 z-50 hidden" data-nosnippet>
        <div class="flex items-center gap-4 rounded-2xl bg-red-600 px-6 py-4 text-white shadow-2xl">
            <span>An unhandled error has occurred.</span>
            <a href="." class="font-medium underline hover:no-underline">Reload</a>
            <button class="text-xl leading-none opacity-70 hover:opacity-100"
                    onclick="document.getElementById('blazor-error-ui').classList.add('hidden')">×</button>
        </div>
    </div>

    <main class="min-h-screen">
        @Body
    </main>
</div>