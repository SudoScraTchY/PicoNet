@using Blazor.Heroicons
@using PicoNet.UI.Components.Shared
@rendermode InteractiveServer

<nav class="flex h-full flex-col">
    <!-- Profile -->
    <div class="mb-8">
        <div class="
            rounded-3xl
            border
            border-[var(--color-border)]
            bg-[var(--color-surface-50)]/80
            p-4
            backdrop-blur">
            <div class="flex items-center gap-3">
                <div class="
                    flex h-14 w-14 shrink-0
                    items-center justify-center
                    rounded-2xl
                    bg-gradient-to-br
                    from-[var(--color-primary-500)]
                    to-[var(--color-accent-500)]
                    font-bold
                    text-white">
                    M
                </div>
                <div class="min-w-0">
                    <div class="
                        truncate
                        font-semibold
                        text-[var(--color-foreground)]">
                        Mehrshad
                    </div>
                    <div class="
                        truncate
                        text-sm
                        text-[var(--color-muted)]">
                        @@example.com
                    </div>
                </div>
            </div>
            <div class="mt-4 flex items-center gap-2">
                <span class="
                    rounded-full
                    bg-[var(--color-success)]/15
                    px-2.5 py-1
                    text-xs
                    font-medium
                    text-[var(--color-success)]">
                    Active
                </span>
                <span class="
                    text-xs
                    text-[var(--color-muted)]">
                    Free Plan
                </span>
            </div>
        </div>
    </div>
    <!-- Navigation -->
    <div class="flex-1">
        <div class="
            mb-3
            px-4
            text-xs
            font-semibold
            uppercase
            tracking-[0.2em]
            text-[var(--color-muted)]">
            Workspace
        </div>
        <div class="space-y-2">
            <NavItem
                Href="/dashboard"
                Text="Dashboard"
                Icon="@(HeroiconName.Home)" />
            <NavItem
                Href="/create"
                Text="Create Link"
                Icon="@(HeroiconName.PlusCircle)" />
            <NavItem
                Href="/analytics"
                Text="Analytics"
                Icon="@(HeroiconName.ChartBarSquare)" />
            <NavItem
                Href="/settings"
                Text="Settings"
                Icon="@(HeroiconName.Cog6Tooth)" />
        </div>
    </div>
    <!-- Dock -->
    <div class="
        border-t
        border-[var(--color-border)]
        pt-6">
        <button class="
            mt-5
            flex
            w-full
            items-center
            gap-3
            rounded-2xl
            px-4
            py-3
            text-sm
            font-medium
            text-[var(--color-error)]
            transition
            hover:bg-[var(--color-error)]/10">
            <Heroicon
                Type="HeroiconType.Mini"
                Name="@(HeroiconName.ArrowLeftStartOnRectangle)"
                class="h-5 w-5" />
            Sign Out
        </button>
    </div>
</nav>