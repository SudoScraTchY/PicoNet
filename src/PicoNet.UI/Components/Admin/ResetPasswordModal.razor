@namespace PicoNet.UI.Components.Admin

@if (_isVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm" @onclick="Cancel"></div>

    <!-- Modal -->
    <div class="fixed inset-x-4 bottom-4 z-50 mx-auto max-w-md rounded-2xl border border-[var(--color-warning)]/30 bg-[var(--color-surface-0)] shadow-2xl">
        <div class="p-6">
            <!-- Header -->
            <div class="mb-4">
                <h3 class="text-lg font-bold text-[var(--color-warning)]">
                    Reset Password?
                </h3>
                <p class="mt-2 text-sm text-[var(--color-muted)]">
                    A temporary password will be generated and sent to the user's email address.
                </p>
            </div>

            <!-- User Email Info -->
            <div class="mb-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] p-3">
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Email</div>
                <div class="mt-1 truncate text-sm font-medium text-[var(--color-foreground)]">
                    @_email
                </div>
            </div>

            <!-- Warning -->
            <div class="mb-6 rounded-lg bg-[var(--color-warning)]/10 p-3 text-sm text-[var(--color-warning)]">
                The user will need to change their password on next login.
            </div>

            <!-- Buttons -->
            <div class="flex gap-3">
                <button
                    type="button"
                    @onclick="Cancel"
                    class="flex-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-0)] px-4 py-2.5 text-sm font-medium text-[var(--color-foreground)] transition hover:bg-[var(--color-surface-50)]">
                    Cancel
                </button>
                <button
                    type="button"
                    @onclick="ConfirmReset"
                    class="flex-1 rounded-lg bg-gradient-to-r from-[var(--color-warning)] to-orange-600 px-4 py-2.5 text-sm font-medium text-white transition hover:scale-[1.02] active:scale-95">
                    Reset Password
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public EventCallback OnConfirm { get; set; }

    private bool _isVisible;
    private string _email = string.Empty;

    public void Show(string email)
    {
        _email = email;
        _isVisible = true;
    }

    private async Task ConfirmReset()
    {
        _isVisible = false;
        await OnConfirm.InvokeAsync();
    }

    private void Cancel()
    {
        _isVisible = false;
    }
}
