@namespace PicoNet.UI.Components.Admin

@if (_isVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm" @onclick="Cancel"></div>

    <!-- Modal -->
    <div class="fixed inset-x-4 bottom-4 z-50 mx-auto max-w-md rounded-2xl border border-[var(--color-error)]/30 bg-[var(--color-surface-0)] shadow-2xl">
        <div class="p-6">
            <!-- Header -->
            <div class="mb-4">
                <h3 class="text-lg font-bold text-[var(--color-error)]">
                    Delete User?
                </h3>
                <p class="mt-2 text-sm text-[var(--color-muted)]">
                    This action cannot be undone. The user will be permanently deleted.
                </p>
            </div>

            <!-- User Info -->
            <div class="mb-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] p-3">
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Username</div>
                <div class="mt-1 truncate text-sm font-medium text-[var(--color-foreground)]">
                    @_username
                </div>
            </div>

            <!-- Buttons -->
            <div class="flex gap-3">
                <button
                    type="button"
                    @onclick="Cancel"
                    class="flex-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-0)] px-4 py-2.5 text-sm font-medium text-[var(--color-foreground)] transition hover:bg-[var(--color-surface-50)]">
                    Cancel
                </button>
                <button
                    type="button"
                    @onclick="ConfirmDelete"
                    class="flex-1 rounded-lg bg-gradient-to-r from-[var(--color-error)] to-red-700 px-4 py-2.5 text-sm font-medium text-white transition hover:scale-[1.02] active:scale-95">
                    Delete User
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public EventCallback OnConfirm { get; set; }

    private bool _isVisible;
    private string _username = string.Empty;

    public void Show(string username)
    {
        _username = username;
        _isVisible = true;
    }

    private async Task ConfirmDelete()
    {
        _isVisible = false;
        await OnConfirm.InvokeAsync();
    }

    private void Cancel()
    {
        _isVisible = false;
    }
}
