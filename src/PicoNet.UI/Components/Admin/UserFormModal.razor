@namespace PicoNet.UI.Components.Admin
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.Contracts.DTOs.Responses.Users
@using PicoNet.Contracts.DTOs.Requests.Users
@using PicoNet.Contracts.DTOs.Responses.Roles
@inject IAdminApiClient AdminApiClient

@if (_isVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm" @onclick="Close"></div>

    <!-- Modal -->
    <div class="fixed inset-x-4 top-1/2 z-50 mx-auto max-w-md -translate-y-1/2 transform rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-0)] shadow-2xl">
        <div class="p-6">
            <!-- Header -->
            <div class="mb-6">
                <h3 class="text-lg font-bold text-[var(--color-foreground)]">
                    @(_isEditMode ? "Edit User" : "Create User")
                </h3>
                <p class="mt-1 text-sm text-[var(--color-muted)]">
                    @(_isEditMode ? "Update user details and roles" : "Create a new user account")
                </p>
            </div>

            @if (_isLoading)
            {
                <div class="flex items-center justify-center py-8">
                    <LoadingSpinner />
                </div>
            }
            else
            {
                <EditForm Model="_formModel" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <!-- Username -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-[var(--color-foreground)] mb-1">Username</label>
                        <InputText
                            @bind-Value="_formModel.Username"
                            placeholder="john.doe"
                            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] px-4 py-2 text-sm placeholder-[var(--color-muted)] transition focus:border-[var(--color-primary-500)] focus:outline-none focus:ring-1 focus:ring-[var(--color-primary-500)]/20"
                            disabled="@_isEditMode" />
                        <ValidationMessage For="@(() => _formModel.Username)" class="mt-1 text-xs text-[var(--color-error)]" />
                    </div>

                    <!-- Email -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-[var(--color-foreground)] mb-1">Email</label>
                        <InputText
                            @bind-Value="_formModel.Email"
                            placeholder="john@example.com"
                            type="email"
                            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] px-4 py-2 text-sm placeholder-[var(--color-muted)] transition focus:border-[var(--color-primary-500)] focus:outline-none focus:ring-1 focus:ring-[var(--color-primary-500)]/20" />
                        <ValidationMessage For="@(() => _formModel.Email)" class="mt-1 text-xs text-[var(--color-error)]" />
                    </div>

                    <!-- Password (only on create) -->
                    @if (!_isEditMode)
                    {
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-[var(--color-foreground)] mb-1">Password</label>
                            <InputText
                                @bind-Value="_formModel.Password"
                                placeholder="••••••••"
                                type="password"
                                class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] px-4 py-2 text-sm placeholder-[var(--color-muted)] transition focus:border-[var(--color-primary-500)] focus:outline-none focus:ring-1 focus:ring-[var(--color-primary-500)]/20" />
                            <ValidationMessage For="@(() => _formModel.Password)" class="mt-1 text-xs text-[var(--color-error)]" />
                        </div>
                    }

                    <!-- Roles Selection -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-[var(--color-foreground)] mb-3">Roles</label>
                        <div class="space-y-2 max-h-48 overflow-y-auto">
                            @if (_availableRoles != null && _availableRoles.Any())
                            {
                                @foreach (var role in _availableRoles)
                                {
                                    var isSelected = _formModel.SelectedRoles?.Contains(role.RoleName) ?? false;
                                    <div class="flex items-center">
                                        <input
                                            type="checkbox"
                                            id="role_@role.RoleName"
                                            @onchange="@((ChangeEventArgs e) => ToggleRole(role.RoleName, (bool)e.Value!))"
                                            checked="@isSelected"
                                            class="h-4 w-4 cursor-pointer rounded border-[var(--color-border)] text-[var(--color-primary-600)]" />
                                        <label for="role_@role.RoleName" class="ml-2 flex-1 cursor-pointer text-sm text-[var(--color-foreground)]">
                                            @role.RoleName
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-[var(--color-muted)]">No roles available</p>
                            }
                        </div>
                    </div>

                    <!-- Error Message -->
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="mb-4 rounded-lg bg-[var(--color-error)]/10 p-3 text-sm text-[var(--color-error)]">
                            @_errorMessage
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="flex gap-3">
                        <button
                            type="button"
                            @onclick="Close"
                            class="flex-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-0)] px-4 py-2.5 text-sm font-medium text-[var(--color-foreground)] transition hover:bg-[var(--color-surface-50)]">
                            Cancel
                        </button>
                        <button
                            type="submit"
                            class="flex-1 rounded-lg bg-gradient-to-r from-[var(--color-primary-600)] to-[var(--color-primary-700)] px-4 py-2.5 text-sm font-medium text-white transition hover:scale-[1.02] active:scale-95">
                            @(_isEditMode ? "Update" : "Create")
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private bool _isVisible;
    private bool _isEditMode;
    private bool _isLoading;
    private string? _errorMessage;
    private UserFormModel _formModel = new();
    private List<RoleResponse>? _availableRoles;
    private Guid _currentUserId;

    public void OpenForCreate()
    {
        _isEditMode = false;
        _formModel = new();
        _isVisible = true;
        _errorMessage = null;
        _ = LoadRoles();
    }

    public void OpenForEdit(Guid userId)
    {
        _isEditMode = true;
        _currentUserId = userId;
        _isVisible = true;
        _errorMessage = null;
        _ = LoadUserAndRoles(userId);
    }

    private async Task LoadRoles()
    {
        try
        {
            var result = await AdminApiClient.ListRolesAsync();
            if (!result.IsError)
            {
                _availableRoles = result.Value;
            }
        }
        catch
        {
            _availableRoles = new List<RoleResponse>();
        }
    }

    private async Task LoadUserAndRoles(Guid userId)
    {
        _isLoading = true;
        try
        {
            var rolesTask = AdminApiClient.ListRolesAsync();
            var userTask = AdminApiClient.GetUserAsync(userId);

            await Task.WhenAll(rolesTask, userTask);

            if (!rolesTask.Result.IsError)
            {
                _availableRoles = rolesTask.Result.Value;
            }

            if (!userTask.Result.IsError)
            {
                var user = userTask.Result.Value;
                _formModel.Username = user.Username;
                _formModel.Email = user.Email;
                _formModel.SelectedRoles = new List<string>(user.Roles);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleRole(string roleName, bool isSelected)
    {
        _formModel.SelectedRoles ??= new List<string>();

        if (isSelected && !_formModel.SelectedRoles.Contains(roleName))
        {
            _formModel.SelectedRoles.Add(roleName);
        }
        else if (!isSelected && _formModel.SelectedRoles.Contains(roleName))
        {
            _formModel.SelectedRoles.Remove(roleName);
        }
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (_isEditMode)
            {
                // Update user
                var updateRequest = new UpdateUserRequest
                {
                    Email = _formModel.Email
                };

                var updateResult = await AdminApiClient.UpdateUserAsync(_currentUserId, updateRequest);
                if (updateResult.IsError)
                {
                    _errorMessage = "Failed to update user";
                    return;
                }

                // Update roles
                var rolesResult = await AdminApiClient.UpdateUserRolesAsync(_currentUserId, _formModel.SelectedRoles ?? new List<string>());
                if (rolesResult.IsError)
                {
                    _errorMessage = "Failed to update roles";
                    return;
                }
            }
            else
            {
                // Create user
                var createRequest = new CreateUserRequest
                {
                    Username = _formModel.Username,
                    Email = _formModel.Email,
                    Password = _formModel.Password,
                    Roles = _formModel.SelectedRoles ?? new List<string>()
                };

                var result = await AdminApiClient.CreateUserAsync(createRequest);
                if (result.IsError)
                {
                    _errorMessage = "Failed to create user";
                    return;
                }
            }

            _isVisible = false;
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close()
    {
        _isVisible = false;
        _errorMessage = null;
    }

    private class UserFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public List<string>? SelectedRoles { get; set; } = new();
    }
}
