@namespace PicoNet.UI.Components.Admin
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.Contracts.DTOs.Requests.Roles
@inject IAdminApiClient AdminApiClient

@if (_isVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm" @onclick="Close"></div>

    <!-- Modal -->
    <div class="fixed inset-x-4 top-1/2 z-50 mx-auto max-w-md -translate-y-1/2 transform rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-0)] shadow-2xl">
        <div class="p-6">
            <!-- Header -->
            <div class="mb-6">
                <h3 class="text-lg font-bold text-[var(--color-foreground)]">
                    Create Role
                </h3>
                <p class="mt-1 text-sm text-[var(--color-muted)]">
                    Create a new role for user management
                </p>
            </div>

            @if (_isLoading)
            {
                <div class="flex items-center justify-center py-8">
                    <LoadingSpinner />
                </div>
            }
            else
            {
                <EditForm Model="_formModel" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <!-- Role Name -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-[var(--color-foreground)] mb-1">Role Name</label>
                        <InputText
                            @bind-Value="_formModel.RoleName"
                            placeholder="Editor, Moderator, etc."
                            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] px-4 py-2 text-sm placeholder-[var(--color-muted)] transition focus:border-[var(--color-primary-500)] focus:outline-none focus:ring-1 focus:ring-[var(--color-primary-500)]/20" />
                        <ValidationMessage For="@(() => _formModel.RoleName)" class="mt-1 text-xs text-[var(--color-error)]" />
                    </div>

                    <!-- Description -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-[var(--color-foreground)] mb-1">Description</label>
                        <InputTextArea
                            @bind-Value="_formModel.Description"
                            placeholder="Describe the purpose of this role..."
                            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-50)] px-4 py-2 text-sm placeholder-[var(--color-muted)] transition focus:border-[var(--color-primary-500)] focus:outline-none focus:ring-1 focus:ring-[var(--color-primary-500)]/20"
                            rows="3" />
                    </div>

                    <!-- Error Message -->
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="mb-4 rounded-lg bg-[var(--color-error)]/10 p-3 text-sm text-[var(--color-error)]">
                            @_errorMessage
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="flex gap-3">
                        <button
                            type="button"
                            @onclick="Close"
                            class="flex-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-0)] px-4 py-2.5 text-sm font-medium text-[var(--color-foreground)] transition hover:bg-[var(--color-surface-50)]">
                            Cancel
                        </button>
                        <button
                            type="submit"
                            class="flex-1 rounded-lg bg-gradient-to-r from-[var(--color-primary-600)] to-[var(--color-primary-700)] px-4 py-2.5 text-sm font-medium text-white transition hover:scale-[1.02] active:scale-95">
                            Create
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private bool _isVisible;
    private bool _isLoading;
    private string? _errorMessage;
    private RoleFormModel _formModel = new();

    public void OpenForCreate()
    {
        _formModel = new();
        _isVisible = true;
        _errorMessage = null;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var createRequest = new CreateRoleRequest
            {
                RoleName = _formModel.RoleName,
                Description = _formModel.Description ?? string.Empty
            };

            var result = await AdminApiClient.CreateRoleAsync(createRequest);
            if (result.IsError)
            {
                _errorMessage = "Failed to create role";
                return;
            }

            _isVisible = false;
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close()
    {
        _isVisible = false;
        _errorMessage = null;
    }

    private class RoleFormModel
    {
        public string RoleName { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
