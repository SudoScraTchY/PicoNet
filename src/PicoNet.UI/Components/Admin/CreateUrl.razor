@page "/create"
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Components.Shared
@inject IUrlApiClient ApiClient
@inject NavigationManager Nav
@rendermode InteractiveServer
<PageTitle>Create Short Link — PicoNet</PageTitle>
<div class="mx-auto max-w-3xl px-5 py-10">
    <div class="mb-8">
        <div class="inline-flex items-center gap-2 rounded-full
                    border border-indigo-200 bg-indigo-50
                    px-3 py-1 text-xs font-medium text-indigo-700
                    dark:border-indigo-900 dark:bg-indigo-950 dark:text-indigo-300">
            Create Link
        </div>
        <h1 class="mt-4 text-4xl font-black tracking-tight
                   text-slate-900 dark:text-white">
            Shorten your URL
        </h1>
        <p class="mt-2 text-slate-500 dark:text-zinc-400">
            Fast links with password protection, click limits and analytics.
        </p>
    </div>
    @if (_errors is { Count: > 0 })
    {
        <div class="mb-6 space-y-3">
            @foreach (var err in _errors)
            {
                <ErrorAlert
                    Message="@err.Description"
                    OnDismiss="@(() => _errors.Remove(err))" />
            }
        </div>
    }
    <EditForm
        Model="_model"
        OnValidSubmit="HandleSubmitAsync"
        FormName="create-url">
        <DataAnnotationsValidator />
        <div class="rounded-3xl border border-slate-200
                    bg-white shadow-sm
                    dark:border-zinc-800
                    dark:bg-zinc-900">
            <div class="p-8 space-y-7">
                @* URL *@
                <div>
                    <label class="mb-2 block text-sm font-semibold">
                        Destination URL
                    </label>
                    <InputText
                        @bind-Value="_model.OriginalUrl"
                        placeholder="https://example.com/article"
                        class=" w-full rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 dark:border-zinc-700 dark:bg-zinc-800 dark:text-white" />
                    <ValidationMessage
                        For="() => _model.OriginalUrl"
                        class="mt-2 text-xs text-red-500" />
                </div>
                @* Alias *@
                <div>
                    <label class="mb-2 block text-sm font-semibold">
                        Custom Alias
                        <span class="ml-1 text-slate-400 font-normal">
                            optional
                        </span>
                    </label>
                    <div class="
                        flex
                        overflow-hidden
                        rounded-2xl
                        border
                        border-slate-200
                        bg-slate-50
                        focus-within:border-indigo-500
                        focus-within:ring-4
                        focus-within:ring-indigo-500/10
                        dark:border-zinc-700
                        dark:bg-zinc-800">
                        <div class="
                            border-r
                            border-slate-200
                            px-4
                            py-4
                            text-sm
                            text-slate-500
                            dark:border-zinc-700">
                            nimmas.ir/u/
                        </div>
                        <InputText
                            @bind-Value="_model.CustomAlias"
                            placeholder="summer-sale"
                            class="
                            flex-1
                            bg-transparent
                            px-4
                            outline-none
                            dark:text-white" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_model.CustomAlias))
                    {
                        <div class="
                            mt-3
                            rounded-xl
                            bg-indigo-50
                            px-4
                            py-3
                            text-sm
                            text-indigo-700
                            dark:bg-indigo-950
                            dark:text-indigo-300">
                            Preview:
                            <span class="font-semibold">
                                nimmas.ir/u/@_model.CustomAlias
                            </span>
                        </div>
                    }
                </div>
                @* Advanced *@
                <details
                    class="
                    rounded-2xl
                    border
                    border-slate-200
                    dark:border-zinc-800">
                    <summary class="
                        cursor-pointer
                        select-none
                        px-5
                        py-4
                        font-semibold">
                        Advanced Options
                    </summary>
                    <div class="space-y-5 px-5 pb-5">
                        <div>
                            <label class="mb-2 block text-sm">
                                Password
                            </label>
                            <InputText
                                @bind-Value="_model.Password"
                                type="password"
                                placeholder="Optional"
                                class="
                                w-full
                                rounded-xl
                                border
                                border-slate-200
                                bg-slate-50
                                px-4
                                py-3
                                dark:border-zinc-700
                                dark:bg-zinc-800" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm">
                                Max Clicks
                            </label>
                            <InputNumber
                                @bind-Value="_model.MaxClicks"
                                class="
                                w-full
                                rounded-xl
                                border
                                border-slate-200
                                bg-slate-50
                                px-4
                                py-3
                                dark:border-zinc-700
                                dark:bg-zinc-800" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm">
                                Tags
                            </label>
                            <InputText
                                @bind-Value="_tagsRaw"
                                placeholder="marketing, q2"
                                class="
                                w-full
                                rounded-xl
                                border
                                border-slate-200
                                bg-slate-50
                                px-4
                                py-3
                                dark:border-zinc-700
                                dark:bg-zinc-800" />
                        </div>
                    </div>
                </details>
            </div>
        </div>
        <div class="mt-8 flex justify-end gap-3">
            <button
                type="button"
                @onclick='() => Nav.NavigateTo("/dashboard")'
                class="
                rounded-2xl
                border
                border-slate-200
                px-5
                py-3
                text-sm
                font-medium">
                Cancel
            </button>
            <button
                type="submit"
                disabled="@(_submitting)"
                class="
                rounded-2xl
                bg-gradient-to-r
                from-indigo-600
                to-violet-600
                px-7
                py-3
                text-sm
                font-semibold
                text-white
                hover:scale-[1.02]
                transition
                disabled:opacity-50">
                @(_submitting
                    ? "Creating..."
                    : "Create Short Link")
            </button>
        </div>
    </EditForm>
</div>