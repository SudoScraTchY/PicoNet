@page "/{ShortCode}"
@using ErrorOr
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Components.Shared
@inject IRedirectClient RedirectClient
@inject NavigationManager Nav

<PageTitle>Redirecting…</PageTitle>

<div class="relative min-h-screen overflow-hidden bg-app text-app transition-colors duration-500">
    <div class="absolute inset-0">
        <div class="absolute left-[-7rem] top-[-8rem] h-80 w-80 rounded-full bg-[rgb(var(--primary)/0.18)] blur-3xl animate-floaty"></div>
        <div class="absolute right-[-8rem] top-[8rem] h-96 w-96 rounded-full bg-[rgb(var(--accent)/0.12)] blur-3xl animate-floaty [animation-delay:1.2s]"></div>
        <div class="absolute bottom-[-10rem] left-[26%] h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--primary-2)/0.10)] blur-3xl animate-floaty [animation-delay:2.4s]"></div>
    </div>

    <div class="relative mx-auto flex min-h-screen max-w-6xl items-center px-6 py-12">
        <div class="grid w-full gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
            <section class="flex flex-col justify-center">
                <div class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-app bg-surface/70 px-4 py-2 text-sm text-muted shadow-soft backdrop-blur">
                    <span class="h-2 w-2 rounded-full bg-[rgb(var(--primary))]"></span>
                    NimMas.ir bridge page
                </div>

                <h1 class="max-w-2xl text-4xl font-black tracking-tight sm:text-6xl">
                    Almost there.
                    <span class="block bg-gradient-to-r from-[rgb(var(--primary))] via-[rgb(var(--primary-2))] to-[rgb(var(--accent))] bg-clip-text text-transparent">
                        We are taking the shortest path.
                    </span>
                </h1>

                <p class="mt-5 max-w-xl text-lg leading-8 text-muted">
                    This page stays visible long enough to show your brand, your message, and your destination cue
                    before the redirect happens.
                </p>

                <div class="mt-8 flex flex-wrap items-center gap-3">
                    <ThemeSwitcher />
                </div>

                <div class="mt-10 grid max-w-2xl gap-4 sm:grid-cols-3">
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Status</div>
                        <div class="mt-1 font-semibold">@StatusLabel</div>
                    </div>
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Short code</div>
                        <div class="mt-1 font-semibold">@ShortCode</div>
                    </div>
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Timer</div>
                        <div class="mt-1 font-semibold">@CountdownLabel</div>
                    </div>
                </div>
            </section>

            <aside class="flex items-center justify-center">
                <div class="w-full max-w-md rounded-[2rem] border border-app bg-surface/75 p-6 shadow-soft backdrop-blur">
                    <div class="rounded-[1.5rem] border border-app bg-app/70 p-5">
                        @if (_loading)
                        {
                            <div class="space-y-5">
                                <div class="flex items-center gap-4">
                                    <RedirectSpinner />
                                    <div>
                                        <div class="text-lg font-semibold">Resolving your link</div>
                                        <div class="text-sm text-muted">Checking destination and preparing the redirect</div>
                                    </div>
                                </div>

                                <div class="h-2 overflow-hidden rounded-full bg-surface-2">
                                    <div class="h-full w-1/3 rounded-full bg-gradient-to-r from-[rgb(var(--primary))] via-[rgb(var(--primary-2))] to-[rgb(var(--accent))] animate-slide-progress"></div>
                                </div>

                                <div class="rounded-2xl bg-surface-2 p-4 text-sm text-muted">
                                    Keep this page open. Your destination is being prepared.
                                </div>
                            </div>
                        }
                        else if (_hasPassword)
                        {
                            <div class="space-y-5">
                                <div>
                                    <div class="text-2xl font-bold">Password protected</div>
                                    <p class="mt-2 text-sm text-muted">Enter the password to continue to the destination.</p>
                                </div>

                                <div>
                                    <label class="mb-2 block text-sm font-medium">Password</label>
                                    <InputText type="password"
                                               @bind-Value="Password"
                                               class="w-full rounded-2xl border border-app bg-surface px-4 py-3 outline-none ring-0 transition focus:border-[rgb(var(--primary))]" />
                                </div>

                                <button class="w-full rounded-2xl bg-[rgb(var(--primary))] px-4 py-3 font-semibold text-white shadow-soft transition hover:scale-[1.01] active:scale-[0.99]"
                                        @onclick="RedirectUrl">
                                    Unlock and continue
                                </button>
                            </div>
                        }
                        else if (_notFound)
                        {
                            <div class="space-y-4">
                                <div class="rounded-2xl bg-red-500/10 p-4 text-red-500">
                                    <div class="text-lg font-bold">Link not found</div>
                                    <div class="mt-1 text-sm">
                                        This short link may be expired, inactive, or incorrect.
                                    </div>
                                </div>

                                <div class="rounded-2xl border border-app bg-surface-2 p-4 text-sm text-muted">
                                    Try checking the URL again or return to the landing page.
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ShortCode { get; set; } = "";
    [Parameter] public string Password { get; set; } = "";

    private bool _loading = true;
    private bool _hasPassword;
    private bool _notFound;
    private string StatusLabel => _loading ? "Resolving" : _hasPassword ? "Locked" : _notFound ? "Unavailable" : "Redirecting";
    private string CountdownLabel => _loading ? "Preparing" : _hasPassword ? "Waiting" : _notFound ? "N/A" : "In progress";

    private const int MinimumVisibleSeconds = 3;
    private DateTime _startedAtUtc;

    protected override async Task OnInitializedAsync()
    {
        _startedAtUtc = DateTime.UtcNow;
        await RedirectUrl();
    }

    private async Task RedirectUrl()
    {
        _loading = true;
        _hasPassword = false;
        _notFound = false;

        var result = await RedirectClient.ResolveAsync(ShortCode, Password);

        if (result.IsError)
        {
            if (result.Errors.Any(x => x.Type == ErrorType.Unauthorized))
            {
                _loading = false;
                _hasPassword = true;
                return;
            }

            _loading = false;
            _notFound = true;
            return;
        }

        var elapsed = (DateTime.UtcNow - _startedAtUtc).TotalSeconds;
        var remaining = MinimumVisibleSeconds - elapsed;

        if (remaining > 0)
            await Task.Delay(TimeSpan.FromSeconds(remaining));

        _loading = false;
        StateHasChanged();

        await Task.Delay(350);

        Nav.NavigateTo(result.Value.OriginalUrl, forceLoad: true);
    }
}