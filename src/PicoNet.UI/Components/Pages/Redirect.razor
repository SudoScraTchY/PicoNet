@page "/{ShortCode}"
@using System.Timers
@using ErrorOr
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Components.Shared
@inject IRedirectClient RedirectClient
@inject NavigationManager Nav

<PageTitle>Redirecting... | NimMas</PageTitle>

<div class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 mesh-gradient"></div>
    <div class="absolute inset-0 bg-background/80 backdrop-blur-3xl"></div>

    <!-- Floating orbs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        @for (int i = 0; i < 6; i++)
        {
            <div class="absolute rounded-full bg-primary-500/20 animate-float"
                 style="width: @(20 + i * 15)px; height: @(20 + i * 15)px;
                        left: @(10 + i * 15)%; top: @(20 + (i % 3) * 25)%;
                        animation-delay: @(i * 0.5)s; animation-duration: @(3 + i * 0.5)s;">
            </div>
        }
    </div>

    @if (_loading)
    {
        <div class="relative z-10 animate-fade-in">
            <LoadingSpinner Text="Resolving your link..." />
        </div>
    }
    else if (_hasPassword)
    {
        <!-- Password Card -->
        <div class="relative z-10 w-full max-w-md mx-4 animate-fade-in-up">
            <div class="rounded-3xl glass border border-border shadow-2xl shadow-primary-500/10 p-8">
                <div class="mx-auto size-16 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center shadow-lg shadow-primary-500/25 mb-6">
                    <svg class="size-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                    </svg>
                </div>

                <h2 class="text-2xl font-bold text-center mb-2">Protected Link</h2>
                <p class="text-muted text-center mb-8">This shortened URL requires a password to access.</p>

                <div class="space-y-4">
                    <div class="relative">
                        <InputText type="password" @bind-Value="@Password"
                                   class="w-full rounded-xl border border-border bg-surface-50 px-4 py-3.5 text-foreground placeholder:text-muted focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all outline-none"
                                   placeholder="Enter password..." />
                    </div>

                    <button @onclick="SubmitPassword"
                            class="w-full rounded-xl bg-gradient-to-r from-primary-600 to-primary-500 text-white font-semibold py-3.5 px-4 hover:shadow-lg hover:shadow-primary-500/25 active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2">
                        <span>Unlock & Continue</span>
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_resolvedUrl != null)
    {
        <!-- Countdown Redirect Card -->
        <div class="relative z-10 w-full max-w-lg mx-4 animate-fade-in-up">
            <div class="rounded-3xl glass border border-border shadow-2xl shadow-primary-500/10 overflow-hidden">
                <!-- Header -->
                <div class="relative h-32 bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center overflow-hidden">
                    <div class="absolute inset-0 opacity-20">
                        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 400 150" preserveAspectRatio="none">
                            <path d="M0,75 Q100,20 200,75 T400,75" fill="none" stroke="white" stroke-width="2" opacity="0.5" />
                            <path d="M0,75 Q100,130 200,75 T400,75" fill="none" stroke="white" stroke-width="2" opacity="0.3" />
                        </svg>
                    </div>
                    <div class="relative text-center text-white">
                        <p class="text-sm font-medium opacity-90 uppercase tracking-wider mb-1">You're almost there</p>
                        <h2 class="text-3xl font-bold">نیم‌راه هستید</h2>
                    </div>
                </div>

                <div class="p-8">
                    <!-- Destination -->
                    <div class="mb-8">
                        <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">Destination</p>
                        <div class="flex items-center gap-3 rounded-xl bg-surface-50 border border-border p-4">
                            <div class="size-10 rounded-lg bg-primary-500/10 flex items-center justify-center shrink-0">
                                <svg class="size-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-foreground truncate">@_resolvedUrl</p>
                                <p class="text-xs text-muted">Original URL</p>
                            </div>
                        </div>
                    </div>

                    <!-- Countdown -->
                    <div class="flex items-center justify-center mb-8">
                        <div class="relative size-24">
                            <svg class="size-24 -rotate-90" viewBox="0 0 100 100">
                                <circle cx="50" cy="50" r="45" fill="none" stroke="var(--border)" stroke-width="6" />
                                <circle cx="50" cy="50" r="45" fill="none" stroke="var(--primary-500)" stroke-width="6"
                                        stroke-linecap="round" stroke-dasharray="283"
                                        class="transition-all duration-1000 ease-linear"
                                        style="stroke-dashoffset: @(_progress * 2.83)" />
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="text-2xl font-bold text-primary-600 dark:text-primary-400">@_countdown</span>
                            </div>
                        </div>
                    </div>

                    <!-- Ad / Self-promotion Card -->
                    <div class="rounded-2xl bg-gradient-to-br from-surface-50 to-surface-100 dark:from-surface-50/50 dark:to-surface-100/50 border border-border p-5 mb-6">
                        <div class="flex items-start gap-4">
                            <div class="size-12 rounded-xl bg-gradient-to-br from-accent-500 to-accent-600 flex items-center justify-center shadow-lg shadow-accent-500/20 shrink-0">
                                <span class="text-white font-bold text-lg">N</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-foreground mb-1">NimMas.ir — نیم مسیر</p>
                                <p class="text-xs text-muted leading-relaxed">The smartest way to shorten your links. Track clicks, protect with passwords, and customize your URLs.</p>
                            </div>
                        </div>
                        <a href="/" class="mt-4 block w-full text-center rounded-lg bg-surface-0 dark:bg-surface-100 border border-border py-2 text-sm font-medium text-foreground hover:border-primary-500 hover:text-primary-600 transition-colors">
                            Learn More
                        </a>
                    </div>

                    <!-- Skip -->
                    <button @onclick="SkipCountdown"
                            class="w-full rounded-xl bg-foreground text-background font-semibold py-3.5 px-4 hover:opacity-90 active:scale-[0.98] transition-all duration-200">
                        Skip & Go Now
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Not Found -->
        <div class="relative z-10 text-center animate-fade-in-up">
            <div class="mx-auto size-24 rounded-full bg-error/10 flex items-center justify-center mb-6">
                <svg class="size-12 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                </svg>
            </div>
            <h2 class="text-3xl font-bold mb-4">Link Not Found</h2>
            <p class="text-muted max-w-md mx-auto mb-8">The short URL you're looking for doesn't exist or is no longer available.</p>

            <div class="flex flex-col gap-3 max-w-sm mx-auto mb-8">
                @foreach (var reason in _errorReasons)
                {
                    <div class="flex items-center gap-3 rounded-xl bg-surface-50 border border-border px-4 py-3">
                        <div class="size-2 rounded-full bg-error shrink-0"></div>
                        <span class="text-sm text-foreground">@reason</span>
                    </div>
                }
            </div>

            <a href="/" class="inline-flex items-center gap-2 rounded-xl bg-primary-600 text-white font-semibold py-3 px-6 hover:shadow-lg hover:shadow-primary-500/25 transition-all">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Back to Home
            </a>
        </div>
    }
</div>

@code {
    [Parameter] public string ShortCode { get; set; } = "";
    [Parameter] public string Password { get; set; } = "";

    private bool _loading = true;
    private bool _hasPassword;
    private string? _resolvedUrl;
    private int _countdown = 5;
    private int _progress;
    private Timer? _timer;

    private const int CountdownSeconds = 5;

    private readonly List<string> _errorReasons =
    [
        "The short URL has expired",
        "The short URL is currently inactive",
        "The short code is incorrect or doesn't exist"
    ];

    protected override async Task OnInitializedAsync()
    {
        await ResolveLink();
    }

    private async Task ResolveLink()
    {
        var result = await RedirectClient.ResolveAsync(ShortCode, Password);

        if (result.IsError)
        {
            if (result.Errors.Any(x => x.Type == ErrorType.Unauthorized))
            {
                _hasPassword = true;
                _loading = false;
                return;
            }
            else
            {
                _loading = false;
                return;
            }
        }

        _resolvedUrl = result.Value.OriginalUrl;
        _loading = false;
        StartCountdown();
    }

    private void StartCountdown()
    {
        _countdown = CountdownSeconds;
        _progress = 100;
        _timer = new Timer(1000);
        _timer.Elapsed += async (_, _) =>
        {
            _countdown--;
            _progress = _countdown * 100 / CountdownSeconds;

            if (_countdown <= 0)
            {
                _timer?.Stop();
                _timer?.Dispose();
                await InvokeAsync(PerformRedirect);
            }

            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void SkipCountdown()
    {
        _timer?.Stop();
        _timer?.Dispose();
        PerformRedirect();
    }

    private void PerformRedirect()
    {
        if (!string.IsNullOrEmpty(_resolvedUrl))
        {
            Nav.NavigateTo(_resolvedUrl, forceLoad: true);
        }
    }

    private async Task SubmitPassword()
    {
        _loading = true;
        await ResolveLink();
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}