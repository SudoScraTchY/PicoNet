@page "/{ShortCode}"
@using ErrorOr
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Components.Shared
@inject IRedirectClient RedirectClient
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(_state == RedirectState.Loading ? "Loading..." : "نیم مسیر - Redirect")</PageTitle>

<div class="min-h-screen flex items-center justify-center p-4 bg-[var(--color-bg-primary)] transition-all duration-500">
    @if (_state == RedirectState.Loading)
    {
        <!-- Loading spinner with brand -->
        <div class="text-center animate-fade-in-up">
            <CompassSpinner />
            <p class="mt-6 text-2xl font-bold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">
                نیم مسیر
            </p>
            <p class="text-sm text-[var(--color-text-secondary)] mt-2">Preparing your path...</p>
        </div>
    }
    else if (_state == RedirectState.PasswordRequired)
    {
        <!-- Password gate -->
        <div class="w-full max-w-md animate-fade-in-up">
            <div class="text-center mb-8">
                <CompassSpinner static />
                <h2 class="mt-4 text-3xl font-extrabold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">Protected Path</h2>
                <p class="mt-2 text-[var(--color-text-secondary)]">This link requires a password</p>
            </div>
            <div class="bg-white/30 dark:bg-black/30 backdrop-blur-xl rounded-3xl p-6 shadow-2xl border border-white/20 dark:border-white/10">
                <div class="flex flex-col gap-4">
                    <input type="password" @bind="Password"
                           placeholder="Enter password"
                           class="w-full px-4 py-3 rounded-xl bg-white/50 dark:bg-black/50 border border-white/30 dark:border-white/20
                                  text-[var(--color-text-primary)] placeholder-[var(--color-text-secondary)]
                                  focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] transition-all" />
                    <button @onclick="SubmitPassword"
                            class="w-full py-3 rounded-xl font-semibold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)]
                                   text-white shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all duration-300">
                        Continue on Path
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_state == RedirectState.NotFound)
    {
        <!-- 404 styled -->
        <div class="text-center animate-fade-in-up">
            <div class="text-8xl font-black bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">404</div>
            <h2 class="mt-4 text-2xl font-bold text-[var(--color-text-primary)]">Halfway Lost</h2>
            <p class="mt-2 text-[var(--color-text-secondary)] max-w-sm mx-auto">
                The path you’re looking for doesn’t exist or has expired.
            </p>
            <a href="/" class="inline-block mt-6 px-6 py-3 rounded-full bg-[var(--color-primary)] text-white hover:bg-[var(--color-accent)] transition-colors duration-300">
                Start a New Journey
            </a>
        </div>
    }
    else if (_state == RedirectState.Ready)
    {
        <!-- Landing interstitial -->
        <div class="w-full max-w-lg animate-fade-in-up">
            <div class="text-center">
                <!-- Brand visual: half circle symbol -->
                <div class="mx-auto w-32 h-32 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center shadow-2xl mb-6">
                    <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </div>
                <h1 class="text-4xl font-extrabold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">
                    نیم مسیر
                </h1>
                <p class="mt-2 text-lg text-[var(--color-text-secondary)]">
                    Your bridge to the destination.
                </p>
                <p class="text-sm text-[var(--color-text-secondary)] mt-1">
                    Redirecting in <span class="font-mono font-bold text-[var(--color-accent)]">@countdown</span>s
                </p>
                <!-- Progress bar -->
                <div class="mt-6 h-1.5 w-full bg-white/30 dark:bg-black/30 rounded-full overflow-hidden backdrop-blur-sm">
                    <div class="h-full bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] transition-all duration-1000 ease-linear"
                         style="width: @((countdown / 5.0 * 100).ToString("F0"))%"></div>
                </div>
                <button @onclick="GoNow"
                        class="mt-6 px-8 py-3 rounded-full font-semibold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)]
                               text-white shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300">
                    Go Now
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string ShortCode { get; set; } = "";

    private RedirectState _state = RedirectState.Loading;
    private string _destination = "";
    private string Password { get; set; } = "";
    private int countdown = 5;
    private Timer? _timer;

    enum RedirectState { Loading, Ready, PasswordRequired, NotFound }

    protected override async Task OnInitializedAsync()
    {
        await ResolveUrl();
    }

    private async Task ResolveUrl()
    {
        // Simulate your actual client call
        ShortCode = "HasPassword"; // for testing password
        var result = await RedirectClient.ResolveAsync(ShortCode, Password);

        if (result.IsError)
        {
            if (result.Errors.Any(e => e.Type == ErrorType.Unauthorized))
            {
                _state = RedirectState.PasswordRequired;
                return;
            }
            _state = RedirectState.NotFound;
            return;
        }

        _destination = result.Value.OriginalUrl;
        _state = RedirectState.Ready;
        StartCountdown();
    }

    private async Task SubmitPassword()
    {
        _state = RedirectState.Loading;
        await ResolveUrl();
    }

    private void StartCountdown()
    {
        _timer = new Timer(async _ =>
        {
            if (countdown > 0)
            {
                countdown--;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                await GoNow();
            }
        }, null, 1000, 1000);
    }

    private async Task GoNow()
    {
        _timer?.Dispose();
        if (!string.IsNullOrEmpty(_destination))
        {
            Nav.NavigateTo(_destination, forceLoad: true);
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}