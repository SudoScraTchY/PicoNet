@page "/not-found"
@layout MainLayout
<PageTitle>404 — نیم مسیر | Lost Along The Way</PageTitle>
<div class="relative min-h-[calc(100vh-72px)] overflow-hidden bg-background text-foreground">
    <div class="absolute inset-0 mesh-gradient opacity-70"></div>
    <div class="absolute left-[10%] top-[15%] size-80 rounded-full bg-primary-500/15 blur-3xl animate-pulse-glow"></div>
    <div class="absolute right-[8%] bottom-[15%] size-[26rem] rounded-full bg-accent-500/15 blur-3xl animate-pulse-glow"
         style="animation-delay:1s">
    </div>
    <div class="relative mx-auto flex min-h-[calc(100vh-72px)] max-w-7xl items-center px-6">
        <div class="grid w-full gap-16 lg:grid-cols-[1.1fr_0.9fr]">
            <!-- Left -->
            <div class="flex flex-col justify-center">
                <div class="mb-5">
                    <div class="inline-flex items-center gap-2 rounded-full border border-primary-500/20 bg-primary-500/10 px-4 py-2">
                        <span class="size-2 rounded-full bg-primary-500 animate-pulse"></span>
                        <span class="text-[11px] uppercase tracking-[0.35em] text-primary-600 dark:text-primary-400">
                            Wrong Route
                        </span>
                    </div>
                </div>
                <div class="text-[7rem] font-black leading-none tracking-[-0.08em] gradient-text sm:text-[9rem]">
                    404
                </div>
                <h1 class="mt-5 max-w-2xl text-4xl font-black tracking-tight sm:text-6xl">
                    Looks like
                    <span class="gradient-text">
                        this path
                    </span>
                    ends here.
                </h1>
                <p class="mt-6 max-w-xl text-lg leading-8 text-muted">
                    The destination could not be reached —
                    but the journey does not end.
                    Return to نیم‌ مسیر and continue with a shorter route.
                </p>
                <div class="mt-10 flex flex-wrap gap-4">
                    <a
                        href="/"
                        class="group inline-flex items-center gap-3 rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-7 py-4 font-semibold text-white transition hover:shadow-xl hover:shadow-primary-500/20">
                        Go Home
                        <svg class="size-5 transition group-hover:translate-x-1"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                        </svg>
                    </a>
                    <button
                        onclick="history.back()"
                        class="rounded-2xl border border-border bg-surface-0 px-7 py-4 font-semibold transition hover:border-primary-500/30">
                        Go Back
                    </button>
                </div>
            </div>
            <!-- Right -->
            <div class="flex items-center justify-center">
                <div class="relative h-[360px] w-full max-w-[620px] rounded-[40px] glass overflow-hidden">
                    <div class="absolute inset-0 mesh-gradient opacity-50"></div>
                    <svg
                        viewBox="0 0 1200 360"
                        class="absolute inset-0 h-full w-full">
                        <defs>
                            <linearGradient
                                id="lostPath"
                                x1="0%"
                                x2="100%">
                                <stop offset="0%" stop-color="var(--color-primary-500)" />
                                <stop offset="100%" stop-color="var(--color-accent-500)" />
                            </linearGradient>
                        </defs>
                        <path
                            d="M80 180 C280 80 420 80 620 180 C760 250 820 80 940 120 C1020 150 1040 230 980 260"
                            fill="none"
                            stroke="url(#lostPath)"
                            stroke-width="7"
                            stroke-linecap="round"
                            stroke-dasharray="14 16"
                            class="animate-path" />
                        <circle
                            cx="80"
                            cy="180"
                            r="16"
                            fill="var(--color-primary-500)" />
                        <circle
                            r="14"
                            fill="var(--color-accent-500)">
                            <animateMotion
                                dur="5s"
                                repeatCount="indefinite">
                                <mpath href="#missing" />
                            </animateMotion>
                        </circle>
                        <circle
                            cx="980"
                            cy="260"
                            r="26"
                            fill="var(--color-error)"
                            opacity=".95" />
                        <line
                            x1="945"
                            x2="1015"
                            y1="225"
                            y2="295"
                            stroke="white"
                            stroke-width="8"
                            stroke-linecap="round"/>
                        <line
                            x1="1015"
                            x2="945"
                            y1="225"
                            y2="295"
                            stroke="white"
                            stroke-width="8"
                            stroke-linecap="round"/>
                    </svg>
                    <div class="absolute bottom-8 left-8">
                        <div class="text-xs uppercase tracking-[0.3em] text-muted">
                            Journey Interrupted
                        </div>
                        <div class="mt-2 text-xl font-bold">
                            Destination Not Found
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>