@page "/ChatGptHome"
@inject NavigationManager Nav

<PageTitle>نیم‌مسیر | NimMas.ir</PageTitle>

<div class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0">
        <div class="absolute left-[-8rem] top-[-6rem] h-72 w-72 rounded-full bg-[rgb(var(--primary)/0.18)] blur-3xl animate-floaty"></div>
        <div class="absolute right-[-7rem] top-[8rem] h-80 w-80 rounded-full bg-[rgb(var(--accent)/0.16)] blur-3xl animate-floaty [animation-delay:1.5s]"></div>
        <div class="absolute bottom-[-8rem] left-[30%] h-96 w-96 rounded-full bg-[rgb(var(--primary-2)/0.14)] blur-3xl animate-floaty [animation-delay:3s]"></div>
    </div>

    <div class="relative mx-auto flex min-h-screen max-w-7xl items-center px-6 py-12">
        <div class="grid w-full gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16">
            <section class="flex flex-col justify-center">
                <div class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-app bg-surface/70 px-4 py-2 text-sm text-muted shadow-soft backdrop-blur">
                    <span class="h-2 w-2 rounded-full bg-[rgb(var(--primary))]"></span>
                    نیم‌مسیر — the shorter path, beautifully presented
                </div>

                <h1 class="max-w-3xl text-5xl font-black tracking-tight sm:text-6xl lg:text-7xl">
                    A smarter
                    <span class="bg-gradient-to-r from-[rgb(var(--primary))] via-[rgb(var(--primary-2))] to-[rgb(var(--accent))] bg-clip-text text-transparent">
                        halfway
                    </span>
                    for your links.
                </h1>

                <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
                    NimMas.ir turns long links into a modern, branded bridge between destination and discovery.
                    Clean redirects, beautiful landing moments, and a visual system that adapts to every theme.
                </p>

                <div class="mt-10 flex flex-wrap gap-4">
                    <button class="rounded-2xl bg-[rgb(var(--primary))] px-6 py-3 font-semibold text-white shadow-soft transition hover:scale-[1.02] active:scale-[0.99]"
                            @onclick="@(() => Nav.NavigateTo("/demo"))">
                        See the bridge
                    </button>

                    <button class="rounded-2xl border border-app bg-surface/70 px-6 py-3 font-semibold text-app shadow-soft transition hover:bg-surface-2"
                            @onclick="@(() => Nav.NavigateTo("/dashboard"))">
                        Open dashboard
                    </button>
                </div>

                <div class="mt-10 grid max-w-2xl gap-4 sm:grid-cols-3">
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Fast</div>
                        <div class="mt-1 text-lg font-semibold">Visible redirect window</div>
                    </div>
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Adaptive</div>
                        <div class="mt-1 text-lg font-semibold">Light + dark themes</div>
                    </div>
                    <div class="rounded-2xl border border-app bg-surface/70 p-4 shadow-soft">
                        <div class="text-sm text-muted">Branded</div>
                        <div class="mt-1 text-lg font-semibold">Palette-driven UI</div>
                    </div>
                </div>
            </section>

            <aside class="flex items-center justify-center">
                <div class="relative w-full max-w-md rounded-[2rem] border border-app bg-surface/75 p-6 shadow-soft backdrop-blur">
                    <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-[rgb(var(--primary)/0.10)] via-transparent to-[rgb(var(--accent)/0.10)]"></div>

                    <div class="relative">
                        <div class="mb-6 flex items-center justify-between">
                            <div>
                                <div class="text-sm text-muted">Visual identity</div>
                                <div class="text-2xl font-bold">Halfway, but premium.</div>
                            </div>
                            <div class="rounded-2xl bg-surface-2 px-3 py-2 text-sm font-semibold">
                                نیم‌ مسیر
                            </div>
                        </div>

                        <div class="space-y-4 rounded-3xl border border-app bg-app/60 p-5">
                            <div class="flex items-center gap-4">
                                <div class="relative h-12 w-12">
                                    <div class="absolute inset-0 rounded-full bg-[rgb(var(--primary)/0.20)] animate-pulse-ring"></div>
                                    <div class="relative flex h-12 w-12 items-center justify-center rounded-full bg-[rgb(var(--primary))] text-white font-black">
                                        N
                                    </div>
                                </div>
                                <div>
                                    <div class="font-semibold">Source → Path → Destination</div>
                                    <div class="text-sm text-muted">A bridge page users actually notice</div>
                                </div>
                            </div>

                            <div class="h-2 overflow-hidden rounded-full bg-surface-2">
                                <div class="h-full w-2/3 rounded-full bg-gradient-to-r from-[rgb(var(--primary))] via-[rgb(var(--primary-2))] to-[rgb(var(--accent))]"></div>
                            </div>

                            <div class="grid grid-cols-2 gap-3 text-sm">
                                <div class="rounded-2xl bg-surface-2 p-3">
                                    <div class="text-muted">Mode</div>
                                    <div class="font-semibold">Live</div>
                                </div>
                                <div class="rounded-2xl bg-surface-2 p-3">
                                    <div class="text-muted">Palette</div>
                                    <div class="font-semibold">Switchable</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>