@* Pages/CreateUrl.razor *@
@page "/create"
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Components.Shared
@inject IUrlApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>Shorten a URL — PicoNet</PageTitle>

<div class="mx-auto max-w-2xl px-4 py-10">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Shorten a URL</h1>
        <p class="mt-1 text-sm text-slate-500">Create a new short link.</p>
    </div>

    @if (_error is not null)
    {
        <div class="mb-6">
            <ErrorAlert Message="@_error" OnDismiss="() => _error = null" />
        </div>
    }

    @* EditForm binds to a model, wires up validation context *@
    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
        
        @* DataAnnotationsValidator hooks FluentValidation via a bridge,
           or standard DataAnnotations — we'll discuss this below *@
        <DataAnnotationsValidator />

        <div class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">

            @* Original URL *@
            <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Destination URL <span class="text-red-500">*</span>
                </label>
                <InputText @bind-Value="_model.OriginalUrl"
                           placeholder="https://example.com/very-long-path"
                           class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm
                                  outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20
                                  dark:border-zinc-700 dark:bg-zinc-800 dark:text-white" />
                <ValidationMessage For="() => _model.OriginalUrl"
                                   class="mt-1 text-xs text-red-600" />
            </div>

            @* Custom Alias *@
            <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Custom alias <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <div class="flex items-center rounded-xl border border-slate-200 bg-slate-50
                            focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-500/20
                            dark:border-zinc-700 dark:bg-zinc-800">
                    <span class="pl-3 text-sm text-slate-400 dark:text-zinc-500 select-none">pico.net/</span>
                    <InputText @bind-Value="_model.CustomAlias"
                               placeholder="my-link"
                               class="flex-1 bg-transparent px-2 py-2 text-sm outline-none dark:text-white" />
                </div>
                <ValidationMessage For="() => _model.CustomAlias"
                                   class="mt-1 text-xs text-red-600" />
            </div>

            @* Tags *@
            <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Tags <span class="text-slate-400 font-normal">(comma-separated)</span>
                </label>
                <InputText @bind-Value="_tagsRaw"
                           placeholder="marketing, q2, campaign"
                           class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm
                                  outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20
                                  dark:border-zinc-700 dark:bg-zinc-800 dark:text-white" />
            </div>

            @* Max Clicks *@
            <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Max clicks <span class="text-slate-400 font-normal">(0 = unlimited)</span>
                </label>
                <InputNumber @bind-Value="_model.MaxClicks"
                             class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm
                                    outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20
                                    dark:border-zinc-700 dark:bg-zinc-800 dark:text-white" />
            </div>

            @* Password *@
            <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Password protection <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <InputText @bind-Value="_model.Password"
                           type="password"
                           placeholder="Leave empty for no password"
                           class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm
                                  outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20
                                  dark:border-zinc-700 dark:bg-zinc-800 dark:text-white" />
            </div>

        </div>

        @* Submit *@
        <div class="mt-6 flex justify-end gap-3">
            <button type="button"
                    @onclick='() => Nav.NavigateTo("/dashboard")'
                    class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium
                           text-slate-700 hover:bg-slate-50 transition-colors">
                Cancel
            </button>
            <button type="submit"
                    disabled="@_submitting"
                    class="rounded-xl bg-indigo-600 px-5 py-2 text-sm font-medium text-white
                           hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                @if (_submitting)
                {
                    <span>Creating…</span>
                }
                else
                {
                    <span>Shorten URL</span>
                }
            </button>
        </div>
        
    </EditForm>
</div>