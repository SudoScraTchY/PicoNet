@if (Open)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm">
        <div class="w-full max-w-lg rounded-[32px] border border-border bg-surface-0 p-8">
            <div class="text-xs uppercase tracking-[0.35em] text-muted">
                Security
            </div>
            <h2 class="mt-2 text-3xl font-black">
                Change Password
            </h2>
            <div class="mt-8 rounded-2xl bg-surface-50 p-5 text-muted">
                Endpoint not implemented yet.
            </div>
            <button
                @onclick="()=>OpenChanged.InvokeAsync(false)"
                class="mt-6 rounded-2xl bg-primary-600 px-5 py-3 text-white">
                Close
            </button>
        </div>
    </div>
}
@code {
    [Parameter]
    public bool Open { get; set; }
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }
}