@page "/validate"
@rendermode InteractiveServer
@using ErrorOr
@using PicoNet.Contracts.DTOs.Requests.Auth
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Services
@inject IAuthApiClient AuthClient
@inject NavigationManager Nav
@inject PendingValidationState PendingValidationState
@inject ICircuitTokenStore TokenStorage

<PageTitle>Validate Email | NimMas</PageTitle>

@if (!_loaded)
{
    <div class="min-h-screen flex items-center justify-center">
        <div class="text-muted animate-pulse">
            Loading validation…
        </div>
    </div>
}
else
{
    <div class="min-h-screen bg-background text-foreground px-4 py-10 flex items-center justify-center">
        <div class="w-full max-w-md rounded-[28px] border border-border bg-surface-0 p-8 shadow-2xl shadow-black/5">

            <div class="mb-8">
                <div class="text-xs uppercase tracking-[0.35em] text-muted">
                    Email validation
                </div>

                <h1 class="mt-3 text-3xl font-black tracking-tight">
                    Enter your token
                </h1>

                <p class="mt-2 text-sm text-muted">
                    We saved your email securely for this session.
                </p>
            </div>

            <EditForm Model="_model" OnValidSubmit="HandleValidateAsync" FormName="validate-form">

                <DataAnnotationsValidator />

                <div class="space-y-4">

                    <div>
                        <label class="mb-2 block text-sm font-medium">
                            Email
                        </label>

                        <InputText
                            @bind-Value="_model.Email"
                            readonly
                            class="w-full rounded-2xl border border-border bg-surface-100 px-4 py-3" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium">
                            Token
                        </label>

                        <InputText
                            @bind-Value="_model.Token"
                            placeholder="Validation token"
                            class="w-full rounded-2xl border border-border bg-surface-50 px-4 py-3 focus:border-primary-500" />
                    </div>

                    <button
                        type="submit"
                        class="w-full rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-4 py-3 font-semibold text-white hover:shadow-lg hover:shadow-primary-500/20">

                        Validate account

                    </button>

                </div>

            </EditForm>

            @if (_errors.Count > 0)
            {
                <div class="mt-6 rounded-2xl border border-error/20 bg-error/10 p-4 text-sm text-error">
                    @foreach (var err in _errors)
                    {
                        <div>@err.Description</div>
                    }
                </div>
            }

        </div>
    </div>
}

@code {

    private readonly ValidateRegistrationRequest _model = new();

    private IList<Error> _errors = [];

    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _model.Email =
            await PendingValidationState.GetEmailAsync()
            ?? "";

        if (string.IsNullOrWhiteSpace(_model.Email))
        {
            Nav.NavigateTo("/register");
            return;
        }

        _loaded = true;
        StateHasChanged();
    }

    private async Task HandleValidateAsync()
    {
        var result =
            await AuthClient.ValidateEmailAsync( _model, CancellationToken.None);

        if (result.IsError)
        {
            _errors = result.Errors;
            return;
        }
        await PendingValidationState.ClearAsync();

        Nav.NavigateTo("/dashboard", forceLoad: true);
    }

}