@page "/confirm-email"
@rendermode InteractiveServer
@using PicoNet.Contracts.DTOs.Requests.Auth
@using PicoNet.UI.ApiClients.Interfaces
@inject IAuthApiClient AuthClient
@inject NavigationManager Nav

<PageTitle>Confirm Email | نیم مسیر</PageTitle>
<div class="relative min-h-screen overflow-hidden bg-background text-foreground">
    <div class="absolute inset-0 mesh-gradient opacity-70"></div>
    <div class="absolute left-[10%] top-[15%] size-72 rounded-full bg-primary-500/15 blur-3xl animate-pulse-glow"></div>
    <div class="absolute right-[8%] bottom-[12%] size-[26rem] rounded-full bg-accent-500/15 blur-3xl animate-pulse-glow"
         style="animation-delay:1s">
    </div>
    <div class="relative flex min-h-screen items-center justify-center px-4">
        <div class="w-full max-w-xl rounded-[36px] border border-border bg-surface-0/90 p-10 shadow-2xl shadow-black/5 backdrop-blur-xl">
            @if (_processing)
            {
                <div class="text-center">
                    <div class="mx-auto mb-8 flex size-20 items-center justify-center rounded-full bg-primary-500/10">
                        <div class="size-8 rounded-full border-[3px] border-primary-500 border-t-transparent animate-spin"></div>
                    </div>
                    <div class="text-xs uppercase tracking-[0.35em] text-muted">
                        Verifying
                    </div>
                    <h1 class="mt-3 text-4xl font-black tracking-tight">
                        Confirming your email
                    </h1>
                    <p class="mt-4 text-muted leading-7">
                        Hold for a moment while we verify your destination.
                    </p>
                </div>
            }
            else if (_success)
            {
                <div class="text-center">
                    <div class="mx-auto mb-8 flex size-24 items-center justify-center rounded-full bg-success/10">
                        <svg class="size-10 text-success"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div class="text-xs uppercase tracking-[0.35em] text-success">
                        Destination Reached
                    </div>
                    <h1 class="mt-3 text-5xl font-black tracking-tight">
                        Email Confirmed
                    </h1>
                    <p class="mt-5 text-lg leading-8 text-muted">
                        Your account is now active.
                        Continue your journey and start shortening smarter.
                    </p>
                    <button
                        @onclick="GoToLogin"
                        class="mt-10 inline-flex items-center gap-3 rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-8 py-4 font-semibold text-white transition hover:shadow-xl hover:shadow-primary-500/25">
                        Continue to Login
                        <svg class="size-5"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/>
                        </svg>
                    </button>
                </div>
            }
            else
            {
                <div class="text-center">
                    <div class="mx-auto mb-8 flex size-24 items-center justify-center rounded-full bg-primary-500/10">
                        <svg class="size-10 text-primary-500"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 8l7.89 4.945a2 2 0 002.22 0L21 8m-16 9h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div class="text-xs uppercase tracking-[0.35em] text-primary-600">
                        One More Step
                    </div>
                    <h1 class="mt-3 text-4xl font-black tracking-tight">
                        Check Your Inbox
                    </h1>
                    <p class="mt-5 text-lg leading-8 text-muted">
                        We've sent a confirmation email.
                        If you don't see it immediately, check:
                    </p>
                    <div class="mt-8 space-y-3 text-left">
                        <div class="rounded-2xl border border-border bg-surface-50 px-5 py-4">
                            📬 Inbox
                        </div>
                        <div class="rounded-2xl border border-border bg-surface-50 px-5 py-4">
                            🗑 Spam / Junk
                        </div>
                        <div class="rounded-2xl border border-border bg-surface-50 px-5 py-4">
                            📂 Promotions / Updates
                        </div>
                    </div>
                    <p class="mt-8 text-sm leading-7 text-muted">
                        Delivery can occasionally take a minute.
                        Once confirmed, return here and continue your journey.
                    </p>
                    <button
                        @onclick="GoToRegister"
                        class="mt-10 rounded-2xl border border-border bg-surface-0 px-8 py-4 font-semibold transition hover:border-primary-500/30 hover:bg-surface-50">
                        Back
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _processing = true;
    private bool _success;
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        
        var userId =  query["userId"];
        var token = query["token"];

        if (string.IsNullOrWhiteSpace(userId) || string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Invalid or missing confirmation link.";
            _processing = false;
            return;
        }

        // You'll need to add this method to your IAuthApiClient
        var response = await AuthClient.ConfirmEmailAsync(new ValidateRegistrationRequest(userId,token), default);
        _success = response.IsSuccess;
        
        if (!_success)
            _errorMessage = "This confirmation link is invalid or has expired.";
            
        _processing = false;
    }

    private void GoToLogin() => Nav.NavigateTo("/login");
    private void GoToRegister() => Nav.NavigateTo("/register");
}