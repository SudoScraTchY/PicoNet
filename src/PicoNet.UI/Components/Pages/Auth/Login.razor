    //
    //         if (!string.IsNullOrEmpty(accessToken))
    //         {
    //             TokenStore.AccessToken = accessToken;
    //         }
    //     }
    // }
    private async Task HandleLoginAsync()
    {
        // Call YOUR server, not the external API
        var result = await UserService.SignInAsync(_model);

        if (!result.IsSuccess)
        {
            //_errors = result.ErrorMessage;
            return;
        }

        // Store user info for the circuit lifetime
        // CurrentUserService.SetUser(new UserSession
        // {
        //     Id = result.Data.Id,
        //     Email = user.Email,
        //     UserName = user.UserName,
        //     DisplayName = user.DisplayName ?? user.Email
        // });
        
        // Force reload to establish auth state in the circuit
        Nav.NavigateTo("/dashboard", forceLoad: true);
    }
}