@page "/login"
@rendermode InteractiveServer
@using ErrorOr
@using Microsoft.AspNetCore.Mvc
@inject CurrentUserTokenAccessor TokenAccessor
@using PicoNet.Contracts.DTOs.Requests.Auth
@using PicoNet.UI.ApiClients.Interfaces
@using PicoNet.UI.Services
@inject IAuthApiClient AuthClient
@inject NavigationManager Nav
@inject ITokenStorage TokenStorage
@inject IBlazorInternalApi Http

<PageTitle>Login | NimMas</PageTitle>
<div class="min-h-screen bg-background text-foreground px-4 py-10 flex items-center justify-center">
    <div class="w-full max-w-md rounded-[28px] border border-border bg-surface-0 p-8 shadow-2xl shadow-black/5">
        <div class="mb-8">
            <div class="text-xs uppercase tracking-[0.35em] text-muted">Welcome back</div>
            <h1 class="mt-3 text-3xl font-black tracking-tight">Sign in</h1>
            <p class="mt-2 text-sm text-muted">Continue to your dashboard and keep building your path.</p>
        </div>
        <form OnValidSubmit="HandleLoginAsync" method="post" action="/api/auth/login" class FormName="landing-login-form">
            <div class="space-y-4">
                <div>
                    <label class="mb-2 block text-sm font-medium">Email</label>
                    <input name="@nameof(_model.Email)" type="@nameof(_model.Email)" placeholder="Email" class="w-full rounded-2xl border border-border bg-surface-50 px-4 py-3 outline-none transition focus:border-primary-500" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-medium">Password</label>
                    <input name="@nameof(_model.Password)" type="@nameof(_model.Password)" placeholder="Password" class="w-full rounded-2xl border border-border bg-surface-50 px-4 py-3 outline-none transition focus:border-primary-500" />
                </div>
                <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-4 py-3 font-semibold text-white transition hover:shadow-lg hover:shadow-primary-500/20 active:scale-[0.99]">
                    Sign in
                </button>
            </div>
        </form>
        @if (_errors is { Count: > 0 })
        {
            <div class="mt-6 rounded-2xl border border-error/20 bg-error/10 p-4 text-sm text-error">
                @foreach (var err in _errors)
                { <div>@err.Description</div> }
            </div>
        }
        <div class="mt-6 text-sm text-muted">
            New here?
            <a class="font-semibold text-primary-600 hover:underline" href="/register">Create an account</a>
        </div>
    </div>
</div>
@code {
    private readonly LoginRequest _model = new();
    private IList<Error> _errors = [];
    
    private async Task HandleLoginAsync()
    {
        // Call YOUR server, not the external API
        var response = await Http.Login(_model);
        
        if (response is { IsSuccess: false, Value.IsSuccessStatusCode: true })
        {
            var problem = await response.Value.Content.ReadFromJsonAsync<ProblemDetails>();
            // handle errors
            return;
        }
    
        // Cookies are automatically set by the browser from the HttpResponse
        // Now do a full redirect to establish the auth cookie in the circuit
        Nav.NavigateTo("/dashboard", forceLoad: true);
    }
}