@using PicoNet.Contracts.DTOs.Responses.Shortener
@using PicoNet.Domain.Enums

<div class="group relative overflow-hidden rounded-xl border border-zinc-200/60 bg-white/90 backdrop-blur-sm transition-all duration-300 hover:border-indigo-300/50 hover:shadow-md dark:border-zinc-800/60 dark:bg-zinc-900/90">
    
    <!-- Subtle Brand Accent -->
    <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-indigo-500/70 via-violet-500/70 to-cyan-500/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

    <div class="p-3.5">
        <!-- Top Section -->
        <div class="flex items-start justify-between gap-3">
            <div class="min-w-0 flex-1">
                <!-- Short URL Row -->
                <div class="mb-2 flex flex-wrap items-center gap-1.5">
                    <div class="inline-flex items-center rounded-lg bg-indigo-50/80 px-2.5 py-1 text-xs font-semibold text-indigo-700 dark:bg-indigo-950/50 dark:text-indigo-300">
                        <span class="opacity-60 mr-0.5">https://NimMas.ir/u/</span>
                        <span class="font-mono">@Url.ShortCode</span>
                    </div>
                    
                    @if (Url.CustomAlias is not null)
                    {
                        <span class="rounded-full bg-emerald-50/80 px-2 py-0.5 text-[11px] font-medium text-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-300">Custom</span>
                    }
                    
                    @if (Url.Status != UrlStatus.Active)
                    {
                        <span class="rounded-full bg-amber-50/80 px-2 py-0.5 text-[11px] font-medium text-amber-700 dark:bg-amber-950/30 dark:text-amber-300">@Url.Status</span>
                    }
                </div>
                
                <!-- Original URL -->
                <div class="mb-2">
                    <div class="text-[10px] uppercase tracking-wider text-zinc-400">Destination</div>
                    <p title="@Url.OriginalUrl" class="mt-0.5 truncate text-xs text-zinc-600 dark:text-zinc-400">@Url.OriginalUrl</p>
                </div>
                
                <!-- Tags -->
                @if (Url.Tags is { Count: > 0 })
                {
                    <div class="flex flex-wrap gap-1.5">
                        @foreach (var tag in Url.Tags)
                        {
                            <span class="rounded-full border border-zinc-200/60 bg-zinc-50/80 px-2 py-0.5 text-[11px] text-zinc-500 dark:border-zinc-700/60 dark:bg-zinc-800/50 dark:text-zinc-400">#@tag</span>
                        }
                    </div>
                }
            </div>
            
            <!-- Action Buttons -->
            <div class="shrink-0 flex gap-2">
                <button @onclick="() => OnCopy.InvokeAsync(Url.ShortCode)" 
                        class="rounded-lg border border-zinc-200/60 bg-white/80 px-3 py-1.5 text-xs font-medium text-zinc-600 transition-all duration-200 hover:border-indigo-300 hover:bg-indigo-50/80 hover:text-indigo-600 active:scale-95 dark:border-zinc-700/60 dark:bg-zinc-900/80 dark:text-zinc-400 dark:hover:bg-indigo-950/50">
                    Copy
                </button>
                <button @onclick="() => OnEdit.InvokeAsync(Url.Id)"
                        class="rounded-lg border border-zinc-200/60 bg-white/80 px-3 py-1.5 text-xs font-medium text-zinc-600 transition-all duration-200 hover:border-blue-300 hover:bg-blue-50/80 hover:text-blue-600 active:scale-95 dark:border-zinc-700/60 dark:bg-zinc-900/80 dark:text-zinc-400 dark:hover:bg-blue-950/50">
                    Edit
                </button>
                <button @onclick="() => OnDelete.InvokeAsync(Url.Id)"
                        class="rounded-lg border border-zinc-200/60 bg-white/80 px-3 py-1.5 text-xs font-medium text-zinc-600 transition-all duration-200 hover:border-red-300 hover:bg-red-50/80 hover:text-red-600 active:scale-95 dark:border-zinc-700/60 dark:bg-zinc-900/80 dark:text-zinc-400 dark:hover:bg-red-950/50">
                    Delete
                </button>
            </div>
        </div>
        
        <!-- Bottom Metrics -->
        <div class="mt-3 flex flex-wrap items-center gap-1.5 border-t border-zinc-100/60 pt-2.5 dark:border-zinc-800/60">
            <div class="rounded-lg bg-zinc-50/80 px-2.5 py-1 text-xs dark:bg-zinc-800/50">
                <span class="text-zinc-400">Clicks</span>
                <span class="ml-1.5 font-semibold text-zinc-700 dark:text-zinc-300">@Url.ClickCount</span>
            </div>
            
            <div class="rounded-lg bg-zinc-50/80 px-2.5 py-1 text-xs dark:bg-zinc-800/50">
                <span class="text-zinc-400">Created</span>
                <span class="ml-1.5 font-medium text-zinc-600 dark:text-zinc-400">@Url.CreatedAt.ToString("MMM d")</span>
            </div>
            
            @if (Url.ExpiresAt is not null)
            {
                <div class="rounded-lg bg-amber-50/80 px-2.5 py-1 text-xs text-amber-700 dark:bg-amber-950/30 dark:text-amber-300">
                    Expires @Url.ExpiresAt.Value.ToString("MMM d")
                </div>
            }
            
            @if (Url.LastAccessedAt is not null)
            {
                <div class="rounded-lg bg-emerald-50/80 px-2.5 py-1 text-xs text-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-300">
                    Active
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ShortUrlResponse Url { get; set; } = null!;
    
    [Parameter]
    public EventCallback<string> OnCopy { get; set; }

    [Parameter]
    public EventCallback<Guid> OnEdit { get; set; }

    [Parameter]
    public EventCallback<Guid> OnDelete { get; set; }
}