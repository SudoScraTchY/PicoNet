@using PicoNet.Contracts.DTOs.Responses.Shortener
@using PicoNet.Domain.Enums

<div class="
group
relative
overflow-hidden
rounded-3xl
border
border-zinc-200/80
bg-white/80
backdrop-blur
transition-all
duration-300
hover:-translate-y-0.5
hover:border-indigo-300
hover:shadow-xl
dark:border-zinc-800
dark:bg-zinc-900/80
dark:hover:border-indigo-800">

    <!-- Brand Accent -->
    <div class="absolute inset-x-0 top-0 h-1
                bg-gradient-to-r
                from-indigo-500
                via-violet-500
                to-cyan-500">
    </div>

    <div class="p-5">

        <!-- Top -->
        <div class="flex items-start justify-between gap-4">

            <!-- Left -->
            <div class="min-w-0 flex-1">

                <!-- Short URL -->
                <div class="mb-3 flex flex-wrap items-center gap-2">

                    <div class="
                        inline-flex
                        items-center
                        rounded-2xl
                        bg-indigo-50
                        px-3
                        py-1.5
                        text-sm
                        font-semibold
                        text-indigo-700
                        dark:bg-indigo-950/60
                        dark:text-indigo-300">

                        <span class="opacity-60 mr-1">
                            nimmas.ir/
                        </span>

                        <span class="font-mono">
                            @Url.ShortCode
                        </span>
                    </div>

                    @if (Url.CustomAlias is not null)
                    {
                        <span class="
                            rounded-full
                            bg-emerald-50
                            px-2.5
                            py-1
                            text-xs
                            font-medium
                            text-emerald-700
                            dark:bg-emerald-950/40
                            dark:text-emerald-300">
                            Custom
                        </span>
                    }

                    @if (Url.Status != UrlStatus.Active)
                    {
                        <span class="
                            rounded-full
                            bg-amber-50
                            px-2.5
                            py-1
                            text-xs
                            font-medium
                            text-amber-700
                            dark:bg-amber-950/40
                            dark:text-amber-300">
                            @Url.Status
                        </span>
                    }

                </div>

                <!-- Original -->
                <div class="mb-4">

                    <div class="text-xs uppercase tracking-wider text-zinc-400">
                        Destination
                    </div>

                    <p
                        title="@Url.OriginalUrl"
                        class="
                            mt-1
                            truncate
                            text-sm
                            text-zinc-700
                            dark:text-zinc-300">

                        @Url.OriginalUrl

                    </p>

                </div>

                <!-- Tags -->
                @if (Url.Tags is { Count: > 0 })
                {
                    <div class="flex flex-wrap gap-2">

                        @foreach (var tag in Url.Tags)
                        {
                            <span class="
                                rounded-full
                                border
                                border-zinc-200
                                bg-zinc-50
                                px-2.5
                                py-1
                                text-xs
                                text-zinc-600
                                dark:border-zinc-700
                                dark:bg-zinc-800
                                dark:text-zinc-300">

                                #@tag

                            </span>
                        }

                    </div>
                }

            </div>

            <!-- Actions -->
            <button
                @onclick="() => OnCopy.InvokeAsync(Url.ShortCode)"
                class="
                    shrink-0
                    rounded-2xl
                    border
                    border-zinc-200
                    bg-white
                    px-4
                    py-2
                    text-sm
                    font-medium
                    text-zinc-700
                    transition
                    hover:border-indigo-300
                    hover:bg-indigo-50
                    hover:text-indigo-700
                    active:scale-95
                    dark:border-zinc-700
                    dark:bg-zinc-900
                    dark:text-zinc-300
                    dark:hover:bg-indigo-950">

                Copy

            </button>

        </div>

        <!-- Bottom Metrics -->
        <div class="
            mt-5
            flex
            flex-wrap
            items-center
            gap-2
            border-t
            border-zinc-100
            pt-4
            dark:border-zinc-800">

            <div class="
                rounded-xl
                bg-zinc-50
                px-3
                py-2
                text-sm
                dark:bg-zinc-800">

                <span class="text-zinc-400">
                    Clicks
                </span>

                <span class="ml-2 font-semibold text-zinc-900 dark:text-white">
                    @Url.ClickCount
                </span>

            </div>

            <div class="
                rounded-xl
                bg-zinc-50
                px-3
                py-2
                text-sm
                dark:bg-zinc-800">

                <span class="text-zinc-400">
                    Created
                </span>

                <span class="ml-2 font-medium text-zinc-700 dark:text-zinc-200">
                    @Url.CreatedAt.ToString("MMM d")
                </span>

            </div>

            @if (Url.ExpiresAt is not null)
            {
                <div class="
                    rounded-xl
                    bg-amber-50
                    px-3
                    py-2
                    text-sm
                    text-amber-700
                    dark:bg-amber-950/30
                    dark:text-amber-300">

                    Expires
                    @Url.ExpiresAt.Value.ToString("MMM d")

                </div>
            }

            @if (Url.LastAccessedAt is not null)
            {
                <div class="
                    rounded-xl
                    bg-emerald-50
                    px-3
                    py-2
                    text-sm
                    text-emerald-700
                    dark:bg-emerald-950/30
                    dark:text-emerald-300">

                    Active

                </div>
            }

        </div>

    </div>

</div>

@code {
    [Parameter, EditorRequired]
    public ShortUrlResponse Url { get; set; } = null!;

    [Parameter]
    public EventCallback<string> OnCopy { get; set; }
}