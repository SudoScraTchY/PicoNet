<div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <div class="mb-3 text-lg font-semibold text-slate-800">
        @Message
    </div>

    @if (!string.IsNullOrWhiteSpace(ActionLabel))
    {
        <button
            @onclick="OnAction"
            class="mt-4 rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">
            @ActionLabel
        </button>
    }
</div>