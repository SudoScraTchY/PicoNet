@rendermode InteractiveServer
@inject IJSRuntime JS

<button @onclick="CycleTheme"
        class="p-2 rounded-full bg-white/20 backdrop-blur border border-white/30 shadow-lg
               hover:bg-white/30 transition-all duration-300
               dark:bg-black/20 dark:border-white/10"
        title="Change color palette">
    <svg class="w-5 h-5 fill-current text-[var(--color-accent)]" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v11a3 3 0 106 0V4a2 2 0 00-2-2H4zm1 14a1 1 0 100-2 1 1 0 000 2zm5-1.757l4.9-4.9a2 2 0 000-2.828L13.485 5.1a2 2 0 00-2.828 0L10 5.757v8.486zM16 18H9.071l6-6H16a2 2 0 012 2v2a2 2 0 01-2 2z" clip-rule="evenodd" />
    </svg>
</button>

@code {
    private string[] themes = new[] { "desert", "ocean", "sunset" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string>("eval", "localStorage.getItem('nimmas-theme') || 'desert'");
            await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme','{stored}')");
        }
    }

    private async Task CycleTheme()
    {
        var current = await JS.InvokeAsync<string>("eval", "document.documentElement.getAttribute('data-theme')");
        var idx = Array.IndexOf(themes, current);
        var next = themes[(idx + 1) % themes.Length];
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme','{next}')");
        await JS.InvokeVoidAsync("eval", $"localStorage.setItem('nimmas-theme','{next}')");
    }
}