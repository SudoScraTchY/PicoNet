<button @onclick="ToggleTheme"
        class="relative size-10 rounded-xl bg-surface-100 dark:bg-surface-50 border border-border
               hover:border-primary-500 transition-all duration-300 flex items-center justify-center
               hover:shadow-lg hover:shadow-primary-500/20 group"
        aria-label="Toggle theme">
    <div class="relative size-5">
        <svg class="absolute inset-0 size-5 text-accent-500 transition-all duration-500 @(IsDark ? "rotate-90 opacity-0 scale-0" : "rotate-0 opacity-100 scale-100")"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg class="absolute inset-0 size-5 text-primary-400 transition-all duration-500 @(IsDark ? "rotate-0 opacity-100 scale-100" : "-rotate-90 opacity-0 scale-0")"
             fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
    </div>
</button>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private bool IsDark { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string?>("localStorage.getItem", "theme");
            IsDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        IsDark = !IsDark;
        await JS.InvokeVoidAsync("toggleTheme");
    }
}