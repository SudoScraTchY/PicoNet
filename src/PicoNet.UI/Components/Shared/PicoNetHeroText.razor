@implements IDisposable
<div class="space-y-6">
    <div class="overflow-hidden">
        <h1
            class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[0.95] animate-fade-in-up">
            @((MarkupString)_current.Title)
        </h1>
    </div>
    <p
        class="max-w-2xl text-lg sm:text-xl text-muted leading-relaxed animate-fade-in">
        @_current.Description
    </p>
</div>
@code {
    private int _index;
    private Timer? _timer;
    private Hero[] Messages =
    [
        new(
            """
            Every link deserves
            <span class='gradient-text'>a better journey</span>
            """,
            "Not just shorter. Faster, cleaner, memorable."
        ),
        new(
            """
            You're already
            <span class='gradient-text'>half-way there</span>
            """,
            "نیم‌مسیر — between intent and destination."
        ),
        new(
            """
            A shorter path.
            <span class='gradient-text'>A clearer arrival.</span>
            """,
            "Transform long forgotten links into experiences."
        ),
        new(
            """
            Stop sharing URLs.
            <span class='gradient-text'>Share direction.</span>
            """,
            "One clean path from click to destination."
        ),
        new(
            """
            Every click
            <span class='gradient-text'>starts somewhere</span>
            """,
            "Make the in-between unforgettable."
        )
    ];
    private Hero _current => Messages[_index];
    protected override void OnInitialized()
    {
        _timer=new(
            _=>{
                _index=
                    (_index+1)
                    %
                    Messages.Length;
                InvokeAsync(
                    StateHasChanged);
            },
            null,
            5000,
            5000);
    }
    public void Dispose()
    {
        _timer?.Dispose();
    }
    private record Hero(
        string Title,
        string Description
    );
}