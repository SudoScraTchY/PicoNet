@implements IDisposable
<div class="space-y-6">
        <h1 class="mx-auto max-w-4xl text-5xl h-auto font-extrabold tracking-tight sm:text-6xl lg:text-7xl mb-6 font-black tracking-tight leading-[0.95] animate-fade-in-up">
            @((MarkupString)Current.Title)
        </h1>
    <p class="max-w-2xl  mx-auto text-lg sm:text-xl text-muted leading-relaxed animate-fade-in">
        @Current.Description
    </p>
</div>
@code {
    private int _index;
    private Timer? _timer;
    private readonly Hero[] _messages =
    [
        new(
            """
            <span class="block text-foreground">Every link deserves</span>
            <span class='gradient-text'>a better journey</span>
            """,
            "Not just shorter. Faster, cleaner, memorable."
        ),
        new(
            """
            <span class="block text-foreground">You're already</span>
            <span class='gradient-text'>half-way there</span>
            """,
            "نیم‌مسیر — between intent and destination."
        ),
        new(
            """
            <span class="block text-foreground">A shorter path.</span>
            <span class='gradient-text'>A clearer arrival.</span>
            """,
            "Transform long forgotten links into experiences."
        ),
        new(
            """
            <span class="block text-foreground">Stop sharing URLs.</span>
            <span class='gradient-text'>Share direction.</span>
            """,
            "One clean path from click to destination."
        ),
        new(
            """
            <span class="block text-foreground">Every click</span>
            <span class='gradient-text'>starts somewhere</span>
            """,
            "Make the in-between unforgettable."
        ),
        new(
            """
            A smarter
            <span class='gradient-text'>halfway</span>
            <span class="text-foreground">for your links.</span>
            """,
            "Make the in-between unforgettable."
        )
    ];
    private Hero Current => _messages[_index];
    protected override void OnInitialized()
    {
        _timer=new(
            _=>{
                _index=
                    (_index+1)
                    %
                    _messages.Length;
                InvokeAsync(
                    StateHasChanged);
            },
            null,
            5000,
            5000);
    }
    public void Dispose()
    {
        _timer?.Dispose();
    }
    private record Hero(
        string Title,
        string Description
    );
}