@using Blazor.Heroicons
<NavLink href="@Href" class="groupflexitems-centergap-3rounded-2xlpx-4py-3text-smfont-mediumtransition"
         ActiveClass="bg-gradient-to-rfrom-indigo-600/20to-violet-600/20text-whiteborderborder-indigo-500/20">
    <span>
        <NavLink
            href="@(Href)"
            class="
        group
        flex
        items-center
        gap-3
        rounded-2xl
        border
        border-transparent
        px-4
        py-3
        text-sm
        font-medium
        text-[var(--color-muted)]
        transition-all
        hover:bg-[var(--color-surface-50)]
        hover:text-[var(--color-foreground)]"
            ActiveClass="
        border-[var(--color-primary-300)]
        bg-[color-mix(in_oklab,var(--color-primary-500)_12%,transparent)]
        text-[var(--color-primary-600)]
        dark:text-[var(--color-primary-400)]">
            <Heroicon
                Type="HeroiconType.Mini"
                Name="@Icon"
                class="
            h-5
            w-5
            transition
            group-hover:scale-110" />
            <span>
                @Text
            </span>
        </NavLink>
    </span>
</NavLink>
@code {
    [Parameter]
    public string Href { get; set; } = "";
    [Parameter]
    public string Text { get; set; } = "";
    [Parameter]
    public string? Icon { get; set; }
}